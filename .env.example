# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,nginx,web1,web2

# PostgreSQL
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_URL=redis://redis:6379/1

# Celery
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_CONCURRENCY=4

# Gunicorn (NFR2 - Resource Management)
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_WORKER_CLASS=sync
GUNICORN_TIMEOUT=30

# Resource pool (NFR2)
INTERNAL_POOL_MAX_CONCURRENCY=16
RESOURCE_CHECKOUT_MAX_CONCURRENCY=8
RESOURCE_PAYMENT_MAX_CONCURRENCY=8
RESOURCE_BATCH_MAX_CONCURRENCY=4
RESOURCE_ACQUIRE_TIMEOUT_SECONDS=1.0

# Payment simulation
PAYMENT_CAPTURE_SIMULATED_DELAY_SECONDS=2
