{
  "info": {
    "name": "High-Performance E-Commerce Engine",
    "_postman_id": "8a6e4b2a-1c45-4d2a-9e10-c3f3f8e0a001",
    "description": "External API testing collection. Covers every public endpoint exposed under /api/v1/ plus health and admin links. Token auth flow is wired in /Auth/Token Login — the test script captures the token and stores it under {{auth_token}} so all subsequent requests pick it up automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{auth_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost", "type": "string" },
    { "key": "auth_token", "value": "", "type": "string" },
    { "key": "username", "value": "user0001", "type": "string" },
    { "key": "password", "value": "Password123!", "type": "string" },
    { "key": "product_id", "value": "1", "type": "string" },
    { "key": "category_id", "value": "1", "type": "string" },
    { "key": "address_id", "value": "1", "type": "string" },
    { "key": "cart_item_id", "value": "1", "type": "string" },
    { "key": "order_id", "value": "1", "type": "string" },
    { "key": "intent_id", "value": "1", "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-applies the bearer token using DRF's `Token <key>` scheme.",
          "if (pm.collectionVariables.get('auth_token')) {",
          "    pm.request.headers.upsert({",
          "        key: 'Authorization',",
          "        value: 'Token ' + pm.collectionVariables.get('auth_token')",
          "    });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0 — Health",
      "item": [
        {
          "name": "Healthz (Nginx)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/healthz", "host": ["{{base_url}}"], "path": ["healthz"] }
          }
        }
      ]
    },

    {
      "name": "1 — Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser_demo\",\n  \"email\": \"newuser_demo@example.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"+963900000000\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "register", ""]
            }
          }
        },

        {
          "name": "Token Login (captures {{auth_token}})",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('auth_token', body.token);",
                  "console.log('Token saved:', body.token.slice(0, 8) + '...');"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/token/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "token", ""]
            }
          }
        },

        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/me/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "me", ""]
            }
          }
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/users/logout/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "logout", ""]
            }
          }
        }
      ]
    },

    {
      "name": "2 — Addresses",
      "item": [
        {
          "name": "List addresses",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/users/addresses/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "addresses", ""]
            }
          }
        },
        {
          "name": "Create address",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"kind\": \"shipping\",\n  \"line1\": \"42 Demo Avenue\",\n  \"line2\": \"Apt 7\",\n  \"city\": \"Damascus\",\n  \"region\": \"\",\n  \"postal_code\": \"12345\",\n  \"country\": \"SY\",\n  \"is_default\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/users/addresses/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "addresses", ""]
            }
          }
        },
        {
          "name": "Make default",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/users/addresses/{{address_id}}/make_default/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "addresses", "{{address_id}}", "make_default", ""]
            }
          }
        },
        {
          "name": "Delete address",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/users/addresses/{{address_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "users", "addresses", "{{address_id}}", ""]
            }
          }
        }
      ]
    },

    {
      "name": "3 — Catalog",
      "item": [
        {
          "name": "List categories",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products/categories/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "categories", ""]
            }
          }
        },
        {
          "name": "List products (paginated, search, ordering)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products/products/?search=Pro&ordering=-price&page=1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "products", ""],
              "query": [
                { "key": "search",   "value": "Pro" },
                { "key": "ordering", "value": "-price" },
                { "key": "page",     "value": "1" }
              ]
            }
          }
        },
        {
          "name": "List products by category",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products/products/?category={{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "products", ""],
              "query": [{ "key": "category", "value": "{{category_id}}" }]
            }
          }
        },
        {
          "name": "Product detail",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/products/products/{{product_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "products", "products", "{{product_id}}", ""]
            }
          }
        }
      ]
    },

    {
      "name": "4 — Cart",
      "item": [
        {
          "name": "Get my cart",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/cart/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", ""]
            }
          }
        },
        {
          "name": "Add item to cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('cart_item_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}},\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/cart/items/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "items", ""]
            }
          }
        },
        {
          "name": "Update cart item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 5\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/cart/items/{{cart_item_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "items", "{{cart_item_id}}", ""]
            }
          }
        },
        {
          "name": "Remove cart item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/cart/items/{{cart_item_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "items", "{{cart_item_id}}", ""]
            }
          }
        },
        {
          "name": "Clear cart",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/v1/cart/clear/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "clear", ""]
            }
          }
        }
      ]
    },

    {
      "name": "5 — Orders",
      "item": [
        {
          "name": "List my orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/orders/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders", ""]
            }
          }
        },
        {
          "name": "Place order from cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('order_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address_id\": {{address_id}},\n  \"billing_address_id\": {{address_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/orders/place/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders", "place", ""]
            }
          }
        },
        {
          "name": "Retrieve order",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/orders/{{order_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders", "{{order_id}}", ""]
            }
          }
        },
        {
          "name": "Cancel order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Changed my mind\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/orders/{{order_id}}/cancel/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders", "{{order_id}}", "cancel", ""]
            }
          }
        }
      ]
    },

    {
      "name": "6 — Inventory",
      "item": [
        {
          "name": "List stock items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/stock-items/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "inventory", "stock-items", ""]
            }
          }
        },
        {
          "name": "Stock item detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/stock-items/{{product_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "inventory", "stock-items", "{{product_id}}", ""]
            }
          }
        },
        {
          "name": "Restock (admin only)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}},\n  \"qty\": 50,\n  \"reference\": \"PO-2026-0001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/stock-items/restock/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "inventory", "stock-items", "restock", ""]
            }
          }
        },
        {
          "name": "Stock movements (audit trail)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/inventory/movements/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "inventory", "movements", ""]
            }
          }
        }
      ]
    },

    {
      "name": "7 — Payments",
      "item": [
        {
          "name": "List my payment intents",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/payments/intents/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "intents", ""]
            }
          }
        },
        {
          "name": "Create payment intent",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('intent_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"order_id\": {{order_id}}\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/payments/intents/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "intents", ""]
            }
          }
        },
        {
          "name": "Capture payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"external_id\": \"pg_test_12345\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/payments/intents/{{intent_id}}/capture/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "intents", "{{intent_id}}", "capture", ""]
            }
          }
        },
        {
          "name": "Refund payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"customer-requested\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/payments/intents/{{intent_id}}/refund/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "intents", "{{intent_id}}", "refund", ""]
            }
          }
        },
        {
          "name": "Webhook (idempotency demo — fire twice with same signature)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Gateway-Signature", "value": "sig_demo_idempotent_001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"payment_captured\",\n  \"intent_id\": {{intent_id}},\n  \"external_id\": \"pg_test_12345\",\n  \"amount\": \"199.99\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payments/webhook/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "webhook", ""]
            }
          }
        }
      ]
    }
  ]
}
